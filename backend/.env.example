# ===============================
# AI Career Dashboard - Backend
# Environment Variables Reference
# ===============================
# Copy this file to .env or set these directly in Render/Railway dashboard

# --- DATABASE (Cloud MySQL) ---
DB_URL=jdbc:mysql://your-host:3306/your_db?createDatabaseIfNotExist=true&useSSL=true&requireSSL=true
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# --- SERVER ---
PORT=8080

# --- FRONTEND URL (for CORS) ---
FRONTEND_URL=https://your-app.vercel.app

# --- FILE UPLOADS (optional: use cloud storage in future) ---
UPLOAD_DIR=uploads

# --- AI API KEYS (future-ready) ---
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=AIza...
